# ELMADHI environment variables
# Copy to .env.local and fill in real values.

# Public site URL (used for metadata, canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://elmadhi.com

# Supabase — the waitlist works without these (logs to server) but will not
# persist. Set them to enable real signups.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
